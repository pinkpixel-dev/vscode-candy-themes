    "gitDecoration.conflictingResourceForeground": "#ffe253",

    "textLink.foreground": "#ff85c2",
    "textLink.activeForeground": "#cc78fc"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#AAAAAA", "fontStyle": "italic" }
    },
    {
      "name": "Comments: Documentation",
      "scope": ["comment.documentation", "comment.block.documentation"],
      "settings": { "foreground": "#85ea3e" }
    },
    {
      "name": "Operators",
      "scope": "keyword.operator",
      "settings": { "foreground": "#ffe253" }
    },
    {
      "name": "Keywords / Storage",
      "scope": ["storage", "keyword.control"],
      "settings": { "foreground": "#ffe253" }
    },
    {
      "name": "Types",
      "scope": ["storage.type", "support.type"],
      "settings": { "foreground": "#85ea3e" }
    },
    {
      "name": "Language Constants",
      "scope": ["constant.language", "support.constant", "variable.language"],
      "settings": { "foreground": "#ff319f" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "support.variable"],
      "settings": { "foreground": "#cc78fc" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#ffe253", "fontStyle": "bold" }
    },
    {
      "name": "Classes",
      "scope": ["entity.other.inherited-class", "support.class", "entity.name.class", "entity.name.type"],
      "settings": { "foreground": "#16f9ee", "fontStyle": "bold" }
    },
    {
      "name": "Numbers, Constants",
      "scope": ["constant.numeric", "constant.character", "constant"],
      "settings": { "foreground": "#16f9ee" }
    },
    {
      "name": "Keywords",
      "scope": "keyword",
      "settings": { "foreground": "#ff85c2" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#ff72b9" }
    },
    {
      "name": "Strings: Escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#16f9ee" }
    },
    {
      "name": "Punctuation for string",
      "scope": "punctuation.definition.string",
      "settings": { "foreground": "#85ea3e" }
    },
    {
      "name": "HTML: Tags",
      "scope": ["meta.tag", "entity.name.tag"],
      "settings": { "foreground": "#ff85c2" }
    },
    {
      "name": "HTML: Attribute Names",
      "scope": ["meta.tag entity.other.attribute-name", "entity.other.attribute-name.html"],
      "settings": { "foreground": "#cc78fc", "fontStyle": "italic" }
    },
    {
      "name": "CSS: Property Names",
      "scope": ["meta.property-name", "support.type.property-name"],
      "settings": { "foreground": "#85ea3e" }
    },
    {
      "name": "CSS: Property Values",
      "scope": ["meta.property-value", "support.constant.property-value"],
      "settings": { "foreground": "#16f9ee" }
    },
    {
      "name": "Markup: Heading",
      "scope": "markup.heading",
      "settings": { "foreground": "#ff85c2", "fontStyle": "bold" }
    },
    {
      "name": "Markup: Bold",
      "scope": "markup.bold",
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markup: Italic",
      "scope": "markup.italic",
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markup Inline",
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#ff9ed8" }
    }
  ]
}
